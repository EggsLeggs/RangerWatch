{
  "name": "rangerai",
  "description": "autonomous wildlife monitoring that identifies species, detects threats, and alerts rangers in real time.",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "repository": {
    "type": "git",
    "url": "git@github.com:EggsLeggs/RangerAI.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/shared",
    "packages/ingest-agent",
    "packages/vision-agent",
    "packages/threat-agent",
    "packages/alert-agent",
    "packages/civic-mcp",
    "packages/dashboard",
    "scripts"
  ],
  "scripts": {
    "bootstrap": "bun install",
    "lint": "bun run --workspaces lint",
    "typecheck": "bun run --workspaces typecheck",
    "test": "bun run --workspaces test",
    "build": "bun run --workspaces build",
    "clean": "bun run --workspaces clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/bun": "^1.3.11",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
