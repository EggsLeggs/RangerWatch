# source of truth for required validation: packages/shared/src/env.ts

# data sources
# optional
INATURALIST_API_KEY=
# required
GBIF_TOKEN=
# required
IUCN_TOKEN=

# vision model + illustrated reports (gpt-4o and dall-e 3 both use this key)
# required
OPENAI_API_KEY=

# guardrails
# required
CIVIC_API_KEY=
# default used when unset
MCP_PORT=3001

# email alerts via Resend (free tier, no carrier registration required)
# optional at load time: email is stubbed without Resend credentials
RESEND_API_KEY=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=

# dashboard/webhook dispatch
# default used when unset
WEBHOOK_URL=http://localhost:3000/api/alerts
# optional: when set, POST /api/alerts requires Authorization: Bearer <key> or x-api-key
DASHBOARD_ALERT_API_KEY=
