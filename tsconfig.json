{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@rangerwatch/shared": [
        "packages/shared/src/index.ts"
      ],
      "@rangerwatch/shared/env": [
        "packages/shared/src/env.ts"
      ],
      "@rangerwatch/shared/mcp-port": [
        "packages/shared/src/mcp-port.ts"
      ]
    }
  },
  "include": [
    "packages/**/*"
  ]
}
